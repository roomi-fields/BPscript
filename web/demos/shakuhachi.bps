// Shakuhachi — Japanese bamboo flute
// 5 notes: ro tsu re chi ri
// Pentatonic with meri (flat) and kari (sharp) ornaments

@core
@controls
@alphabet.shakuhachi:browser
@mm:50

S -> Phrase1 Phrase2 End

Phrase1 -> ro tsu re chi ri (wave:sine, vel:75, attack:100, release:300)
Phrase2 -> ri _ chi re _ tsu ro _
End -> ro _ _ _ _ (vel:55)
