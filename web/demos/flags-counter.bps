// Flags Counter — guards et mutations de flags

@core
@controls
@alphabet.western:browser

// Init : compteur à 4
S -> Phrase [count=4]

-----

// Chaque passage décrémente le compteur
@mode:random
when count-1 Phrase -> C4 E4 G4 Phrase [weight:50]
when count-1 Phrase -> D4 F4 A4 Phrase [weight:30]
when count-1 Phrase -> E4 G4 B4 Phrase

// Quand count atteint 0, on termine
Phrase -> C5 _ _ _
