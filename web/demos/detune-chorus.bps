// Detune Chorus — effet de désaccordage
// Démo : [detune:N] en cents (100 cents = 1 demi-ton)
// Comparer sans et avec détune

@core
@controls
@alphabet.western:browser
@mm:50

S -> Normal Detuned

// Sans détune
Normal -> [wave:sawtooth, vel:70] C3 _ E3 _ G3 _ C4 _

// Avec détune (50 cents = quart de ton)
Detuned -> [wave:sawtooth, vel:70, detune:50] C3 _ E3 _ G3 _ C4 _
