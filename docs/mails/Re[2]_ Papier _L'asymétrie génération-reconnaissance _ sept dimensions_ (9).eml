>pour le stage de ce WE avec Andr=C3=A9ine :D
>
>Une part de moi resterait bien l=C3=A0 =C3=A0 travailler sur le sujet, je=
=20
>commence a avoir un truc qui marche bien :)
>
>Bref voici les fichiers modifi=C3=A9s.
>
>   CompileProcs.c =E2=80=94 12 lignes chang=C3=A9es autour de la ligne 357 =
:
>   // AVANT (1 ligne) :
>   if(!control && (mode =3D=3D 1) && (c =3D=3D -80)) {  /* -80 is '=C2=B0' =
*/
>
>   // APR=C3=88S (accepte 'inf' OU le byte Latin-1 =C2=B0) :
>   if(!control && (mode =3D=3D 1) && (c =3D=3D 'i' || c =3D=3D -80)) {
>       if(c =3D=3D 'i' && *((*qq)+1) =3D=3D 'n' && *((*qq)+2) =3D=3D 'f')=
 {
