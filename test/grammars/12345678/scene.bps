// ek-do-tin.bps — Tihai de Kathak (ek do tin char panch che sat at)
// Traduit de bp3-engine/library/tabla/ek-do-tin/grammar.gr
//
// Démontre les contrôles de performance sur les sound objects.
// Pitch bend continu avec templates (transpositions successives du tihai).
// Terminaux : bols de tabla (ek, do, tin, char, panch, che, sat, at)

@core
@controls
@sound.tabla_perc
@tempo:88
@striated

// --- Sous-grammaire 1 @mode:ord ---

@mode:ord
S -> $Tihai(chromashift:-2) &Tihai(pitchcont, pitchbend:-200, chromashift:-2) &Tihai(pitchbend:200) (pitchrange:200)

Tihai -> {Huit}:2 {Six}:2 {Cinq}:2 {Quatre}:2 - {- - ek - - do - - tin - - -}:3
Huit -> ek do tin char panch che sat at
Six -> ek do tin char panch che
Cinq -> ek do tin char panch
Quatre -> ek do tin char
