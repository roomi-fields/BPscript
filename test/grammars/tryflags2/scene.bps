[@maxitems:25]   // MaxItemsProduce=25 dans le reglage natif : le moteur s'arrete
                 // apres 25 items. Sans ce plafond l'enumeration part vers 100000 et
                 // certaines grammaires ne rendent jamais la main.
@mode:random
S -> X X X X X X X X X X [make_b=1]
[make_b-1] X -> b [make_c+1]
[make_c-1] X -> c [make_b+1]
X -> a
