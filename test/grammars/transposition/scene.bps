// transposition.bps — transpositions imbriquées par Harm Visser (1997)
// Traduit de bp3-engine/library/examples/transposition/grammar.gr
//
// Polymétrie imbriquée avec transpositions progressives (+2, +4, +6)
// et répétition contrôlée par flag numtimes.
// Tr2/Tr4/Tr6 sont des non-terminaux résolus par SUB1 en _transpose().

@core
@controls
@alphabet.western:midi

// --- Sous-grammaire 1 @mode:random ---

@mode:random
S -> A [numtimes=5]
A -> {E1,A#1 F#1} {Tr2 D}
B -> {Tr2 A}
C -> {Tr4 B}
[numtimes-1] D -> - {Tr6 C {B}[speed:1]} {C}[speed:1] repeat(4)

-----

// --- Sous-grammaire 2 @mode:sub1 — résolution transpositions ---

@mode:sub1
Tr2 -> transpose(2)
Tr4 -> transpose(4)
Tr6 -> transpose(6)
D -> lambda
