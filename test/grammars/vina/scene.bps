// vina.bps — Gitam "Sri Gananaada" en raga Malahari (premier cycle)
// Traduit de bp3-engine/library/tabla/vina/grammar.gr
//
// Démontre les gamakas (ornements) de la vina :
// - Pull (pitchbend) pour les tirés de corde
// - Slide (paramètre continu) pour les glissandos
// Terminaux : notes indiennes (mandra_sa, mandra_pa, mandra_ni, madhya_sa)

@core
@controls
@alphabet.sargam:midi
@diapason:261.625  // ancre OCCIDENTALE, comme le natif : il plaque le sargam sur la grille
                   // western (sa4 = C4 = 261.625 Hz) au lieu de l'ancre traditionnelle 240 Hz.
                   // Le CATALOGUE reste intact (sargam ancre sa=240) — c'est la SCENE qui declare,
                   // arbitrage Romain 2026-07-19. Sans cette ligne, la piece sonne juste mais
                   // transposee d'environ 1,5 demi-ton vers le grave (facteur constant 0.917).

// --- Sous-grammaire 1 @mode:random — structure ---

@mode:random
S -> Sri Ga Na Naa Da
Sri -> {StartSlide StartPull mandra_sa _ Pull0 Slide0 _ Pull2 Slide5 _ Pull0 _ Pull2 _ Pull0 Slide5 _ Slide7 _ _ _ _ _ StopSlide StopPull}:2
Ga -> {LightGamaka mandra_pa}:1
Na -> {madhya_sa}:1
Naa -> {Spurita mandra_ni}:1
Da -> {LightGamaka madhya_sa}:1

-----

// --- Sous-grammaire 2 @mode:sub1 — structures intermédiaires ---

@mode:sub1
LightGamaka ?1 -> StartPull ?1 _ _ Pull0 _ Pull1 _ Pull0 _ _ _ Pull1 StopPull
Spurita ?1 -> StartSlide ?1 Slide1 _ _ _ _ _ _ _ Slide1 StopSlide

-----

// --- Sous-grammaire 3 @mode:sub1 — résolution en contrôles ---

@mode:sub1
Pull0 -> pitchbend(0)
Pull1 -> pitchbend(100)
Pull2 -> pitchbend(200)
Slide0 -> value(slide,0)
Slide1 -> value(slide,101)
Slide5 -> value(slide,501)
Slide7 -> value(slide,701)
StartSlide -> cont(slide) value(slide,0)
StopSlide -> fixed(slide)
StartPull -> pitchcont pitchrange(500) pitchbend(0)
StopPull -> pitchfixed
