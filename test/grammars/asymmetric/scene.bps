// asymmetric.bps — Rythmes asymétriques africains
// Traduit de bp3-engine/library/experimental/asymmetric/grammar.gr
// Ref: Marc Chemillier, "Les Mathématiques naturelles" (Odile Jacob, 2007 p. 127)
//
// Cycle de 24 beats avec transformations a/b construisant des patterns asymétriques.
// Les terminaux '3' et '2' de BP3 (quoted symbols = durées de beats)
// deviennent beat3 et beat2 en BPscript.

@core
@controls

gate beat3:midi
gate beat2:midi

// --- Sous-grammaire 1 @mode:random — initialisation ---

@mode:random
S -> Head U V [Reverse=0, beats=24, K1]

-----

// --- Sous-grammaire 2 @mode:random — choix du nombre de B (impair) ---

@mode:random
Head -> Head goto(3,0) [B=3, A=3] [weight:3]
Head -> Head goto(3,0) [B=9, A=1] [weight:1]

-----

// --- Sous-grammaire 3 @mode:random — choix d'une transformation ---

@mode:random
[K1-1] [A>0] Head -> Head a [Atrans, A-1, K2, K3]
[K1-1] [B>0] Head -> Head b [Btrans, B-1, K4]

-----

// --- Sous-grammaire 4 @mode:ord — transformation a ---

@mode:ord
[K2-1] [Atrans] U -> beat3 U
[K3-1] [Atrans-1] V -> beat3 V

-----

// --- Sous-grammaire 5 @mode:ord — transformation b ---

@mode:ord
[K4-1] [Btrans-1] [Reverse==1] U -> beat2 U [Reverse=0]
[K4-1] [Btrans-1] [Reverse==0] V -> beat2 V [Reverse=1]

-----

// --- Sous-grammaire 6 @mode:random — reboucler si transformations restantes ---

@mode:random
[A>=1] Head -> Head goto(3,0) [K1]
[B>=1] Head -> Head goto(3,0) [K1]

-----

// --- Sous-grammaire 7 @mode:random — effacement des variables ---

@mode:random
U ->
V ->
Head ->
