// check& — silent sound objects rewrite
// Original: -gr.check& (French notes → opaque terminals)
// _pitchrange/_pitchbend/_pitchcont → _script(CTn)
// Rule 7 crashes WASM (long ties + pitchbend), kept for completeness

RND
gram#1[1] <1-1> S --> {do3_-,sol4&,mi5 _rest}{fa3_,&sol4-}
gram#1[2] <1-1> S --> do3& re3 do3 mi3 &do3
gram#1[3] <1-1> S --> do3& re3& do3 mi3 &do3 &re3
gram#1[4] <1-1> S --> {do3 _& -,sol4&,mi5 _rest}{fa3 _,- &sol4 -} &do3__
gram#1[5] S --> {do3__& mi5,sol4&,mi5 _rest}{mi5,&do3 _ _}{fa3 _,&sol4 -}
gram#1[6] <1-1> S --> {do3 _& -,sol4&,mi5 _rest}{&do3_&,- &sol4 -} &do3__
gram#1[7] S --> _script(CT 0) _script(CT 1) _script(CT 2) do4___& {&do4______________&,sol4______________} &do4___ _script(CT 3)

// controlTable:
// CT0 = {pitchrange: 200}
// CT1 = {pitchbend: -200}
// CT2 = {pitchcont: 1}
// CT3 = {pitchbend: 200}
