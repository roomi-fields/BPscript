{
  "name": "controls",
  "description": "BPscript controls — layered by scope: engine [] / runtime () with transport sub-groups",
  "version": "0.3.0",

  "subgrammar": {
    "_comment": "@mode:X(modifier) syntax — emitted as BP3 preamble between mode line and rules",
    "destru": {
      "bp3": "_destru",
      "args": [],
      "description": "Destructure composed terminals based on alphabet"
    },
    "striated": {
      "bp3": "_striated",
      "args": [],
      "description": "Striated time (pulsed)"
    },
    "smooth": {
      "bp3": "_smooth",
      "args": [],
      "description": "Smooth time (non-pulsed)"
    },
    "mm": {
      "bp3": "_mm",
      "args": ["bpm"],
      "description": "Absolute metronome marking (BPM)"
    }
  },

  "engine": {
    "_comment": "[] syntax — translated directly to BP3 instructions by the transpiler",
    "tempo": {
      "bp3": "_tempo",
      "args": ["ratio"],
      "description": "Relative tempo multiplier"
    },
    "repeat": {
      "bp3": "_repeat",
      "args": ["expr"],
      "description": "Controlled repetition. expr = K-param or K-param=value."
    },
    "failed": {
      "bp3": "_failed",
      "args": ["subgrammar", "rule"],
      "description": "Jump on derivation failure."
    },
    "stop": {
      "bp3": "_stop",
      "args": [],
      "description": "Stop derivation."
    },
    "goto": {
      "bp3": "_goto",
      "args": ["subgrammar", "rule"],
      "description": "Jump to specific subgrammar and rule."
    },
    "retro": {
      "bp3": "_retro",
      "args": [],
      "description": "Retrograde — reverse element order in polymetric context."
    },
    "staccato": {
      "bp3": "_staccato",
      "args": ["value"],
      "range": [0, 127],
      "description": "Staccato — shorten note durations (affects temporal structure)"
    },
    "legato": {
      "bp3": "_legato",
      "args": ["value"],
      "range": [0, 127],
      "description": "Legato — extend note durations (affects temporal structure)"
    }
  },

  "runtime": {
    "_comment": "() syntax — transpiler emits _script(CTn), dispatcher interprets at playback. Sub-groups define transport scope.",

    "musical": {
      "_comment": "Transport-agnostic controls — every transport interprets them in its own protocol",
      "vel": {
        "args": ["value"],
        "range": [0, 127],
        "default": 64,
        "description": "Velocity (0-127). WebAudio: gain, MIDI: NoteOn velocity"
      },
      "pan": {
        "args": ["value"],
        "range": [0, 127],
        "default": 64,
        "description": "Pan (0=left, 64=center, 127=right). WebAudio: StereoPanner, MIDI: CC10"
      },
      "rndvel": {
        "args": ["range"],
        "default": 0,
        "description": "Random velocity +/-range"
      },
      "velcont": {
        "args": [],
        "description": "Enable continuous velocity interpolation"
      },
      "offvel": {
        "args": ["value"],
        "range": [0, 127],
        "default": 64,
        "description": "NoteOff velocity (0-127). Relevant for expressive controllers (Osmose, MPE)"
      }
    },

    "midi": {
      "_comment": "MIDI-specific controls — only meaningful for MIDI transport",
      "chan": {
        "args": ["channel"],
        "range": [1, 16],
        "default": 1,
        "description": "MIDI channel"
      },
      "ins": {
        "args": ["program"],
        "range": [1, 128],
        "default": 0,
        "description": "MIDI Program Change"
      },
      "mod": {
        "args": ["value"],
        "range": [0, 127],
        "default": 0,
        "description": "MIDI Modulation (CC1)"
      },
      "modcont": {
        "args": [],
        "description": "Enable continuous modulation interpolation (CC1)"
      },
      "pitchbend": {
        "args": ["value"],
        "range": [-8192, 8191],
        "default": 0,
        "description": "MIDI Pitch Bend"
      },
      "pitchrange": {
        "args": ["cents"],
        "default": 200,
        "description": "Pitch bend range in cents"
      },
      "pitchcont": {
        "args": [],
        "description": "Enable continuous pitch bend interpolation"
      },
      "pitchfixed": {
        "args": [],
        "description": "Disable continuous pitch bend mode"
      },
      "pressure": {
        "args": ["value"],
        "range": [0, 127],
        "default": 0,
        "description": "MIDI Channel Pressure (aftertouch)"
      },
      "press": {
        "args": ["value"],
        "range": [0, 127],
        "default": 0,
        "description": "MIDI Channel Pressure (alias for pressure)"
      },
      "presscont": {
        "args": [],
        "description": "Enable continuous channel pressure interpolation"
      },
      "volume": {
        "args": ["value"],
        "range": [0, 127],
        "default": 100,
        "description": "MIDI Volume (CC7)"
      },
      "volumecont": {
        "args": [],
        "description": "Enable continuous volume interpolation"
      },
      "switchon": {
        "args": ["channel"],
        "description": "Enable MIDI switch channel"
      },
      "switchoff": {
        "args": ["channel"],
        "description": "Disable MIDI switch channel"
      },
      "script": {
        "args": ["command"],
        "description": "MIDI script command (program change sequences, etc.)"
      },
      "cc": {
        "args": ["number", "value"],
        "range": [0, 127],
        "description": "Generic MIDI CC: cc(number, value). For CCs without a named alias."
      }
    },

    "webaudio": {
      "_comment": "Web Audio specific controls",
      "wave": {
        "args": ["type"],
        "values": ["sine", "triangle", "square", "sawtooth"],
        "default": "triangle",
        "description": "Oscillator waveform (Web Audio)"
      },
      "attack": {
        "args": ["ms"],
        "range": [1, 5000],
        "default": 20,
        "description": "Envelope attack in ms (Web Audio)"
      },
      "release": {
        "args": ["ms"],
        "range": [1, 5000],
        "default": 100,
        "description": "Envelope release in ms (Web Audio)"
      },
      "detune": {
        "args": ["cents"],
        "range": [-1200, 1200],
        "default": 0,
        "description": "Detune in cents (Web Audio)"
      },
      "filter": {
        "args": ["freq"],
        "range": [20, 20000],
        "default": 0,
        "description": "Lowpass filter cutoff Hz (Web Audio)"
      },
      "filterQ": {
        "args": ["value"],
        "range": [0, 30],
        "default": 1,
        "description": "Filter resonance Q (Web Audio)"
      }
    },

    "dispatcher": {
      "_comment": "Resolved by the dispatcher before reaching any transport — musical transformations",
      "transpose": {
        "args": ["steps"],
        "default": 0,
        "description": "Transposition — grid shift of N steps in the temperament"
      },
      "scale": {
        "args": ["name", "blockkey"],
        "default": "0,0",
        "description": "Microtonal scale — name + base note. scale(0,0) = back to equal temperament."
      },
      "rotate": {
        "args": ["degrees"],
        "default": 0,
        "description": "Cyclic rotation — shift N degrees in the alphabet (diatonic). rotate(2): C->E, D->F, etc."
      },
      "keyxpand": {
        "args": ["pivot", "factor"],
        "default": "0,1",
        "description": "Interval expansion/contraction around a pivot. factor=2 doubles, factor=-1 inverts, factor=0.5 contracts."
      }
    },

    "generic": {
      "_comment": "Sound object parameter controls — transport-agnostic, forwarded as-is",
      "value": {
        "args": ["param", "amount"],
        "description": "Continuous sound object parameter value"
      },
      "fixed": {
        "args": ["param", "amount"],
        "description": "Fixed sound object parameter value"
      },
      "cont": {
        "args": ["param"],
        "description": "Enable continuous mode for a parameter"
      }
    }
  }
}
