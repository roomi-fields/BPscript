{
  "name": "+",
  "description": "BPscript performance controls — compile to BP3 _ prefixed commands",
  "version": "0.1.0",
  "controls": {
    "tempo": {
      "bp3": "_tempo",
      "args": [
        "ratio"
      ],
      "description": "Multiplicateur de tempo relatif"
    },
    "mm": {
      "bp3": "_mm",
      "args": [
        "bpm"
      ],
      "description": "Marquage métronomique absolu (BPM)"
    },
    "vel": {
      "bp3": "_vel",
      "args": [
        "value"
      ],
      "range": [
        0,
        127
      ],
      "description": "Vélocité MIDI (état, affecte tout ce qui suit)"
    },
    "chan": {
      "bp3": "_chan",
      "args": [
        "channel"
      ],
      "range": [
        1,
        16
      ],
      "description": "Canal MIDI (état, affecte tout ce qui suit)"
    },
    "staccato": {
      "bp3": "_staccato",
      "args": [
        "value"
      ],
      "range": [
        0,
        127
      ],
      "description": "Staccato — raccourcit la durée des notes"
    },
    "legato": {
      "bp3": "_legato",
      "args": [
        "value"
      ],
      "range": [
        0,
        127
      ],
      "description": "Legato — prolonge la durée des notes"
    },
    "pan": {
      "bp3": "_pan",
      "args": [
        "value"
      ],
      "range": [
        0,
        127
      ],
      "description": "Panoramique MIDI"
    },
    "mod": {
      "bp3": "_mod",
      "args": [
        "value"
      ],
      "range": [
        0,
        127
      ],
      "description": "Modulation MIDI (CC1)"
    },
    "pitchbend": {
      "bp3": "_pitchbend",
      "args": [
        "value"
      ],
      "range": [
        -8192,
        8191
      ],
      "description": "Pitch bend MIDI"
    },
    "pitchrange": {
      "bp3": "_pitchrange",
      "args": [
        "cents"
      ],
      "description": "Plage de pitch bend en cents (définit l'étendue de pitchbend)."
    },
    "pitchcont": {
      "bp3": "_pitchcont",
      "args": [],
      "description": "Active l'interpolation continue de pitch bend."
    },
    "pressure": {
      "bp3": "_pressure",
      "args": [
        "value"
      ],
      "range": [
        0,
        127
      ],
      "description": "Channel pressure MIDI"
    },
    "ins": {
      "bp3": "_ins",
      "args": [
        "program"
      ],
      "range": [
        1,
        128
      ],
      "description": "Program change MIDI"
    },
    "transpose": {
      "bp3": "_transpose",
      "args": [
        "semitones"
      ],
      "description": "Transposition en demi-tons"
    },
    "striated": {
      "bp3": "_striated",
      "args": [],
      "description": "Bascule en temps strié"
    },
    "smooth": {
      "bp3": "_smooth",
      "args": [],
      "description": "Bascule en temps lisse"
    },
    "repeat": {
      "bp3": "_repeat",
      "args": [
        "expr"
      ],
      "description": "Répétition contrôlée. expr = K-paramètre ou K-paramètre=valeur."
    },
    "failed": {
      "bp3": "_failed",
      "args": [
        "subgrammar",
        "rule"
      ],
      "description": "Saut en cas d'échec de dérivation."
    },
    "stop": {
      "bp3": "_stop",
      "args": [],
      "description": "Arrête la dérivation."
    },
    "goto": {
      "bp3": "_goto",
      "args": [
        "subgrammar",
        "rule"
      ],
      "description": "Saut vers une sous-grammaire et règle spécifiques. Usage bas niveau — préférer on_fail quand possible."
    },
    "scale": {
      "bp3": "_scale",
      "args": [
        "name",
        "root"
      ],
      "description": "Active une gamme nommée avec une note de référence. root=0 pour pas de transposition."
    },
    "volume": {
      "bp3": "_volume",
      "args": [
        "value"
      ],
      "range": [
        0,
        127
      ],
      "description": "Volume MIDI (CC7)"
    },
    "volumecont": {
      "bp3": "_volumecont",
      "args": [],
      "description": "Active l'interpolation continue de volume entre les points _volume()."
    },
    "rotate": {
      "bp3": "_rotate",
      "args": [
        "semitones"
      ],
      "description": "Rotation de pitch — décale cycliquement les notes dans l'espace des hauteurs."
    },
    "keyxpand": {
      "bp3": "_keyxpand",
      "args": [
        "note",
        "direction"
      ],
      "description": "Expansion/contraction de clavier autour d'une note pivot. direction: 1=expand, -1=contract."
    },
    "velcont": {
      "bp3": "_velcont",
      "args": [],
      "description": "Active l'interpolation continue de vélocité entre les points _vel()."
    },
    "retro": {
      "bp3": "_retro",
      "args": [],
      "description": "Rétrograde — inverse l'ordre des éléments dans le contexte polymétrique."
    },
    "rndvel": {
      "bp3": "_rndvel",
      "args": [
        "range"
      ],
      "description": "Vélocité aléatoire — ajoute une variation aléatoire ±range à la vélocité courante."
    },
    "value": {
      "bp3": "_value",
      "args": [
        "param",
        "amount"
      ],
      "description": "Valeur d'un paramètre continu de sound object (Csound/MIDI CC)."
    },
    "fixed": {
      "bp3": "_fixed",
      "args": [
        "param",
        "amount"
      ],
      "description": "Valeur fixe d'un paramètre de sound object (pas d'interpolation)."
    },
    "cont": {
      "bp3": "_cont",
      "args": [
        "param"
      ],
      "description": "Active le mode continu pour un paramètre de sound object."
    },
    "script": {
      "bp3": "_script",
      "args": [
        "command"
      ],
      "description": "Commande script BP3 (MIDI program change, etc.)."
    },
    "pitchfixed": {
      "bp3": "_pitchfixed",
      "args": [],
      "description": "Désactive le mode continu de pitch bend."
    },
    "switchon": {
      "bp3": "_switchon",
      "args": [
        "channel"
      ],
      "description": "Active un canal MIDI switch."
    },
    "switchoff": {
      "bp3": "_switchoff",
      "args": [
        "channel"
      ],
      "description": "Désactive un canal MIDI switch."
    },
    "press": {
      "bp3": "_press",
      "args": [
        "value"
      ],
      "range": [
        0,
        127
      ],
      "description": "Channel pressure MIDI"
    },
    "presscont": {
      "bp3": "_presscont",
      "args": [],
      "description": "Active l'interpolation continue de channel pressure."
    },
    "modcont": {
      "bp3": "_modcont",
      "args": [],
      "description": "Active l'interpolation continue de modulation (CC1)."
    },
    "wave": {
      "bp3": "_wave",
      "args": ["type"],
      "values": ["sine", "triangle", "square", "sawtooth"],
      "description": "Forme d'onde de l'oscillateur (Web Audio). Défaut: triangle.",
      "transport": "webaudio"
    },
    "attack": {
      "bp3": "_attack",
      "args": ["ms"],
      "range": [1, 5000],
      "description": "Temps d'attaque de l'enveloppe en ms. Défaut: 20ms.",
      "transport": "webaudio"
    },
    "release": {
      "bp3": "_release",
      "args": ["ms"],
      "range": [1, 5000],
      "description": "Temps de relâchement de l'enveloppe en ms. Défaut: 100ms.",
      "transport": "webaudio"
    },
    "detune": {
      "bp3": "_detune",
      "args": ["cents"],
      "range": [-1200, 1200],
      "description": "Désaccordage en cents (Web Audio). 100 cents = 1 demi-ton.",
      "transport": "webaudio"
    },
    "filter": {
      "bp3": "_filter",
      "args": ["freq"],
      "range": [20, 20000],
      "description": "Fréquence de coupure du filtre passe-bas en Hz. 0 = pas de filtre.",
      "transport": "webaudio"
    },
    "filterQ": {
      "bp3": "_filterQ",
      "args": ["value"],
      "range": [0, 30],
      "description": "Résonance (Q) du filtre. Défaut: 1.",
      "transport": "webaudio"
    }
  }
}