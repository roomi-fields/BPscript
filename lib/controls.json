{
  "name": "controls",
  "description": "BPscript controls — engine [] and runtime () separated",
  "version": "0.2.0",

  "engine": {
    "_comment": "[] syntax — translated directly to BP3 instructions by the transpiler",
    "tempo": {
      "bp3": "_tempo",
      "args": ["ratio"],
      "description": "Multiplicateur de tempo relatif"
    },
    "mm": {
      "bp3": "_mm",
      "args": ["bpm"],
      "description": "Marquage métronomique absolu (BPM)"
    },
    "striated": {
      "bp3": "_striated",
      "args": [],
      "description": "Bascule en temps strié"
    },
    "smooth": {
      "bp3": "_smooth",
      "args": [],
      "description": "Bascule en temps lisse"
    },
    "repeat": {
      "bp3": "_repeat",
      "args": ["expr"],
      "description": "Répétition contrôlée. expr = K-paramètre ou K-paramètre=valeur."
    },
    "failed": {
      "bp3": "_failed",
      "args": ["subgrammar", "rule"],
      "description": "Saut en cas d'échec de dérivation."
    },
    "stop": {
      "bp3": "_stop",
      "args": [],
      "description": "Arrête la dérivation."
    },
    "goto": {
      "bp3": "_goto",
      "args": ["subgrammar", "rule"],
      "description": "Saut vers une sous-grammaire et règle spécifiques."
    },
    "scale": {
      "bp3": "_scale",
      "args": ["name", "root"],
      "description": "Active une gamme nommée avec une note de référence."
    },
    "retro": {
      "bp3": "_retro",
      "args": [],
      "description": "Rétrograde — inverse l'ordre des éléments dans le contexte polymétrique."
    },
    "rotate": {
      "bp3": "_rotate",
      "args": ["semitones"],
      "description": "Rotation de pitch — décale cycliquement les notes."
    },
    "keyxpand": {
      "bp3": "_keyxpand",
      "args": ["note", "direction"],
      "description": "Expansion/contraction de clavier autour d'une note pivot."
    }
  },

  "runtime": {
    "_comment": "() syntax — transpiler emits _script(CTn), dispatcher interprets at playback",
    "vel": {
      "args": ["value"],
      "range": [0, 127],
      "description": "Vélocité (0-127)"
    },
    "chan": {
      "args": ["channel"],
      "range": [1, 16],
      "description": "Canal MIDI"
    },
    "pan": {
      "args": ["value"],
      "range": [0, 127],
      "description": "Panoramique (0=gauche, 64=centre, 127=droite)"
    },
    "transpose": {
      "args": ["semitones"],
      "description": "Transposition en demi-tons"
    },
    "ins": {
      "args": ["program"],
      "range": [1, 128],
      "description": "Program change MIDI"
    },
    "staccato": {
      "args": ["value"],
      "range": [0, 127],
      "description": "Staccato — raccourcit la durée des notes"
    },
    "legato": {
      "args": ["value"],
      "range": [0, 127],
      "description": "Legato — prolonge la durée des notes"
    },
    "mod": {
      "args": ["value"],
      "range": [0, 127],
      "description": "Modulation MIDI (CC1)"
    },
    "pitchbend": {
      "args": ["value"],
      "range": [-8192, 8191],
      "description": "Pitch bend MIDI"
    },
    "pitchrange": {
      "args": ["cents"],
      "description": "Plage de pitch bend en cents"
    },
    "pitchcont": {
      "args": [],
      "description": "Active l'interpolation continue de pitch bend"
    },
    "pitchfixed": {
      "args": [],
      "description": "Désactive le mode continu de pitch bend"
    },
    "pressure": {
      "args": ["value"],
      "range": [0, 127],
      "description": "Channel pressure MIDI"
    },
    "press": {
      "args": ["value"],
      "range": [0, 127],
      "description": "Channel pressure MIDI (alias)"
    },
    "presscont": {
      "args": [],
      "description": "Active l'interpolation continue de channel pressure"
    },
    "volume": {
      "args": ["value"],
      "range": [0, 127],
      "description": "Volume MIDI (CC7)"
    },
    "volumecont": {
      "args": [],
      "description": "Active l'interpolation continue de volume"
    },
    "velcont": {
      "args": [],
      "description": "Active l'interpolation continue de vélocité"
    },
    "rndvel": {
      "args": ["range"],
      "description": "Vélocité aléatoire ±range"
    },
    "modcont": {
      "args": [],
      "description": "Active l'interpolation continue de modulation (CC1)"
    },
    "value": {
      "args": ["param", "amount"],
      "description": "Valeur d'un paramètre continu de sound object"
    },
    "fixed": {
      "args": ["param", "amount"],
      "description": "Valeur fixe d'un paramètre de sound object"
    },
    "cont": {
      "args": ["param"],
      "description": "Active le mode continu pour un paramètre"
    },
    "script": {
      "args": ["command"],
      "description": "Commande script (MIDI program change, etc.)"
    },
    "switchon": {
      "args": ["channel"],
      "description": "Active un canal MIDI switch"
    },
    "switchoff": {
      "args": ["channel"],
      "description": "Désactive un canal MIDI switch"
    },
    "wave": {
      "args": ["type"],
      "values": ["sine", "triangle", "square", "sawtooth"],
      "description": "Forme d'onde oscillateur (Web Audio)",
      "transport": "webaudio"
    },
    "attack": {
      "args": ["ms"],
      "range": [1, 5000],
      "description": "Attaque enveloppe en ms (Web Audio)",
      "transport": "webaudio"
    },
    "release": {
      "args": ["ms"],
      "range": [1, 5000],
      "description": "Relâchement enveloppe en ms (Web Audio)",
      "transport": "webaudio"
    },
    "detune": {
      "args": ["cents"],
      "range": [-1200, 1200],
      "description": "Désaccordage en cents (Web Audio)",
      "transport": "webaudio"
    },
    "filter": {
      "args": ["freq"],
      "range": [20, 20000],
      "description": "Fréquence de coupure filtre passe-bas Hz (Web Audio)",
      "transport": "webaudio"
    },
    "filterQ": {
      "args": ["value"],
      "range": [0, 30],
      "description": "Résonance (Q) du filtre (Web Audio)",
      "transport": "webaudio"
    }
  }
}
