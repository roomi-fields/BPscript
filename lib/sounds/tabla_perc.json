{
  "description": "Tabla percussion synthesis — bayan (bass) + dayan (treble)",
  "defaults": {
    "decay": 150,
    "noise": 0.3,
    "brightness": 2000
  },
  "templates": {
    "bayan_open": { "freq": 80, "noise": 0.15, "decay": 350, "brightness": 1200, "pitch_drop": 0.6 },
    "bayan_muted": { "freq": 80, "noise": 0.1, "decay": 60, "brightness": 600, "pitch_drop": 0.3 },
    "dayan_ring": { "freq": 350, "noise": 0.4, "decay": 250, "brightness": 4000, "pitch_drop": 0.1 },
    "dayan_sharp": { "freq": 400, "noise": 0.85, "decay": 25, "brightness": 6000, "pitch_drop": 0.05 },
    "dayan_light": { "freq": 300, "noise": 0.5, "decay": 80, "brightness": 3000, "pitch_drop": 0.15 }
  },
  "by_terminal": {
    "dhin": { "layers": ["bayan_open", "dayan_ring"] },
    "dha": { "layers": ["bayan_open", "dayan_ring"] },
    "ge": { "layers": ["bayan_open"] },
    "ghe": { "layers": ["bayan_open"] },
    "ka": { "layers": ["bayan_muted"] },
    "ke": { "layers": ["dayan_sharp"] },
    "na": { "layers": ["dayan_ring"] },
    "ta": { "layers": ["dayan_sharp"] },
    "ti": { "layers": ["dayan_light"] },
    "tin": { "layers": ["dayan_ring"], "override": { "freq": 500, "decay": 150 } },
    "tun": { "layers": ["bayan_open"], "override": { "decay": 400 } },
    "dhagena": { "layers": ["bayan_open", "dayan_ring"], "override": { "decay": 120 } },
    "tirakita": { "layers": ["dayan_sharp", "dayan_light"], "override": { "decay": 40, "brightness": 5000 } },
    "dheene": { "layers": ["bayan_open", "dayan_ring"], "override": { "decay": 100 } },
    "dheena": { "layers": ["bayan_open", "dayan_ring"], "override": { "decay": 100 } },
    "teene": { "layers": ["dayan_ring", "dayan_light"], "override": { "decay": 100 } },
    "teena": { "layers": ["dayan_ring", "dayan_light"], "override": { "decay": 100 } },
    "gena": { "layers": ["bayan_open", "dayan_ring"], "override": { "decay": 100 } },
    "kena": { "layers": ["dayan_sharp", "dayan_ring"], "override": { "decay": 80 } },
    "tage": { "layers": ["dayan_sharp", "bayan_open"], "override": { "decay": 80 } },
    "dhati": { "layers": ["bayan_open", "dayan_light"], "override": { "decay": 100 } },
    "dhage": { "layers": ["bayan_open", "bayan_muted"], "override": { "decay": 80 } },
    "trkt": { "layers": ["dayan_sharp"], "override": { "decay": 30, "noise": 0.9 } },
    "kt": { "layers": ["dayan_sharp"], "override": { "decay": 20, "noise": 0.9 } },
    "tidha": { "layers": ["dayan_light", "bayan_open"], "override": { "decay": 80 } },
    "dhati": { "layers": ["bayan_open", "dayan_light"], "override": { "decay": 100 } },
    "teenake": { "layers": ["dayan_ring", "dayan_sharp"], "override": { "decay": 80 } },
    "dheenage": { "layers": ["bayan_open", "dayan_ring"], "override": { "decay": 80 } },
    "dhatrkt": { "layers": ["bayan_open", "dayan_sharp"], "override": { "decay": 60 } },
    "trktdha": { "layers": ["dayan_sharp", "bayan_open"], "override": { "decay": 60 } },
    "teenakena": { "layers": ["dayan_ring", "dayan_sharp"], "override": { "decay": 80 } },
    "dheenagena": { "layers": ["bayan_open", "dayan_ring"], "override": { "decay": 80 } },
    "ek": { "layers": ["dayan_light"], "override": { "freq": 250, "decay": 60 } },
    "do": { "layers": ["dayan_light"], "override": { "freq": 280, "decay": 60 } },
    "char": { "layers": ["dayan_light"], "override": { "freq": 260, "decay": 60 } },
    "panch": { "layers": ["dayan_light"], "override": { "freq": 270, "decay": 60 } },
    "che": { "layers": ["dayan_light"], "override": { "freq": 290, "decay": 60 } },
    "sat": { "layers": ["dayan_light"], "override": { "freq": 310, "decay": 60 } },
    "at": { "layers": ["dayan_light"], "override": { "freq": 320, "decay": 60 } }
  }
}
