// koto3.bps — Automate cellulaire 1D, "musique turque" (Bernard Bel)
// Traduit de bp3-engine/library/experimental/koto3/grammar.gr
//
// Méta-grammaire : les règles SUB construisent dynamiquement des polymétriques.
// Les { } , apparaissent comme terminaux bruts sur le LHS et dans les contextes.

@core
@controls

gate a:midi
gate b:midi
gate c:midi
gate f:midi
gate chik:midi

// --- Sous-grammaire 1 [mode:random] — séquence initiale ---

S -> X X X X Y X X X X Y X X X X [mode:random, weight:100, vel:127, volume:40]
X -> a [weight:K9]
X -> b

-----

// --- Sous-grammaire 2 [mode:sub] — automate cellulaire ---

Y -> Y [mode:sub]
#? ?1 -> #? ?1
?1 #? -> ?1 #?
} -> }
, -> ,
a -> a [weight:5]
a b a -> a a [weight:30]
#({) a b a -> {a c b,f f f - f} [speed:5] [weight:100]
b -> b [weight:5]
#({) b a b #(}) -> b b [weight:30]
#({) b a b -> {b a b c b a,f a f} [speed:3] [weight:100]
#({) #a b #(}) -> #a c b [weight:100-10]
c c c -> c a c
c a c -> b a b
?1 ?1 ?2 ?3 ?4 ?4 -> ?2 ?3 [weight:50]
?1 ?1 ?1 -> ?1 [weight:K9]
?1 ?1 -> ?1 [weight:K9]

-----

// --- Sous-grammaire 3 [mode:random] — silences et out-time objects ---

Y -> !f [mode:random, weight:40]
Y -> !chik [weight:50]
? #? -> ? Silence script(MIDI send Continue) #? [weight:1-1]
Silence -> - - - - - [weight:50]
Silence -> - - - - [weight:15]
Silence -> - - - [weight:8]
Silence -> - - [weight:8]
