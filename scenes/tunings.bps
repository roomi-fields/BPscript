// tunings.bps — Tuning systems comparison
// Traduit de bp3-engine/library/examples/tunings/grammar.gr

@core
@+
@western:midi

// --- Sous-grammaire 1 [mode:ord] ---

S -> tempo(2) scale(bach_temperament,0) Up_Down [mode:ord]
S -> tempo(2) scale(pure_minor-third_meantone,0) Up_Down
S -> tempo(2) scale(meantone_classic,0) Up_Down
S -> tempo(2) Up_Down

Up_Down -> Diatonic_scale_up Altered_scale_down
Diatonic_scale_up -> C4 D4 E4 F4 G4 A4 B4 C5
Diatonic_scale_down -> {retro Diatonic_scale_up}
Altered_scale_up -> C4 Db4 Eb4 F#4 G4 Ab4 Bb4 C5
Altered_scale_down -> {retro Altered_scale_up}

Temp -> Cmaj Fmaj Dmin Gmaj Cmaj
Just -> scale(Cmaj,0) Cmaj scale(Fmaj,0) Fmaj scale(Dmin,0) Dmin scale(Gmaj,0) Gmaj scale(Cmaj,0) Cmaj

Cmaj -> {C3,C4,E4,G4}
Fmaj -> {F3,C4,F4,A4}
Dmin -> {D3,D4,F4,A4}
Gmaj -> {G3,B3,D4,G4}

Dmaj -> {D3,D4,F#4,A4}
Cmin -> {C3,C4,Eb4,G4}
