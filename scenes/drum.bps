// drum.bp — pattern de batterie en 3 voix polymétriques
// Traduit de bp3-engine/library/examples/drum/grammar.gr

@core
@controls
@alphabet.western:midi

// Trois voix : kick (C8), snare (C7), hihat (E7)
// Chaque voix a des durées différentes → polymétrie naturelle
S -> {
  [chan:1, vel:120, staccato:96]C8 - - -,
  [chan:1, vel:120, staccato:96]- C7 C7 C7,
  [chan:1, vel:120, staccato:92]E7 E7 E7 E7 E7 E7 E7 E7
}
