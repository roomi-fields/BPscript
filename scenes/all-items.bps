// all-items.bps — Produce all items (test templates)
// Traduit de bp3-engine/library/examples/all-items/grammar.gr

@core
@controls

gate a:midi
gate b:midi

// --- Sous-grammaire 1 [mode:random] ---

@mode:random
S -> $X X &X
S -> X X

-----

// --- Sous-grammaire 2 [mode:random, destru] ---

@mode:random
X -> a [destru]
X -> b
