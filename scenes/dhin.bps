// dhin.bps — Qa'ida pour tabla (BP1 → BP3)
// Traduit de bp3-engine/library/tabla/dhin/grammar.gr
//
// Conventions de renommage:
//   BP3 `*(: X)` → `&X[sub:dhin]` (homomorphisme pas encore implémenté,
//     traduit comme &X avec commentaire)
//   BP3 `4+4/6` → non-terminal meter8 (time signature inline)
//   BP3 `4+4+4+4/6` → non-terminal meter16
//   BP3 `)` comme terminal → ) direct (RawBrace sur LHS)
//   Les terminaux sont des bols de tabla (dhin, dha, dhagena, tirakita...)

@core
@controls

// --- Sous-grammaire 1 [mode:random] — structure ---

S <> S96 [mode:random, weight:0, meter:4+4/6]
S <> S192 [weight:5, meter:4+4+4+4/6]

-----

// --- Sous-grammaire 2 [mode:random] — sections ---
// NOTE: *(: X) = homomorphisme. Traduit comme &X (replay sans substitution).
// L'implémentation de [sub:dhin] appliquera la substitution dha→ta, ge→ke, etc.

S192 <> $ {F48} $ {V24} F'24 & {F48} & {V24} F24 [mode:random, weight:5]
S96 <> $ {V24} F'24 & {V24} F24 [weight:0]
V24 <> $ {V12} & {V12} [weight:0]
V24 <> $ {V12} & {V12} [weight:1]
V24 <> Q24 [weight:0]
V24 <> V12 V12 [weight:0]
V24 <> B24 [weight:4]
V12 <> $ {B6} & {B6} [weight:0]
V12 <> B12 [weight:1]

-----

// --- Sous-grammaire 3 [mode:lin] — décomposition rythmique ---

B3 <> A3 [mode:lin, weight:2]
B4 <> A4 [weight:0]
B6 <> A6 [weight:2]
B6 <> C6 [weight:0]
B24 <> A3 B21 [weight:3]
B24 <> A4 B20 [weight:0]
