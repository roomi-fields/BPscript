B9 <> C6 B3 [weight:0]
B8 <> A4 B4 [weight:0]
B6 <> A3 B3 [weight:2]

-----

// --- Sous-grammaire 4 [mode:random] — résolution en bols ---

A3 <> dhin - - [mode:random, weight:4]
A3 <> dha - - [weight:0]
A3 <> dhagena [weight:0]
A3 A3 <> dhagena dhin - - [weight:2]
A3 A3 <> dhagena dha - - [weight:5]
A4 <> tirakita [weight:0]
A6 <> dha - dha - dha - [weight:0]
A6 <> dha - ta - dha - [weight:0]
A6 <> dheene dheene dheene [weight:0]
A6 <> dheene dha - dheene [weight:1]
A6 <> dheene dheena gena [weight:5]
A6 <> teene teena kena [weight:1]
A6 <> dhati ge gena ka [weight:0]
C6 <> tage tirakita [weight:0]

-----

// --- Sous-grammaire 5 [mode:random] — phrases longues ---

F'12 <> dhati ge gena ka teene teena kena [mode:random, weight:1]
Q24 <> dhin - - dhagena dha - - dhagena dhati ge gena ka dheene dheena gena [weight:0]
F24 <> tage tirakita dhin - - dhagena dhati ge gena ka dheene dheena gena [weight:5]
F24 <> tage tirakita gena - dhagena dhati ge gena ka dheene dheena gena [weight:0]
F'24 <> tage tirakita dhin - - dhagena dhati ge gena ka teene teena kena [weight:5]
F'24 <> tage tirakita gena - dhagena dhati ge gena ka teene teena kena [weight:0]
F48 <> dhin - - dhagena dha - - dhagena dhati ge gena ka dheene dheena gena tage tirakita dhin - - dhagena dhati ge gena ka teene teena kena [weight:5]
