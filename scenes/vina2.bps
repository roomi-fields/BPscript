// vina2.bps — Gitam "Sri Gananaada" (variante avec pitch bend polymétrique)
// Traduit de bp3-engine/library/tabla/vina2/grammar.gr

@core
@controls
@alphabet.bp3_indian:midi
// L'alphabet PORTE l'ancre native (dha4 = A4 = 440 Hz, donc sa4 = C4 = 261.6256) et sa
// propre table de registres : BP3 RENOMME le clavier occidental, il ne le transpose pas.
// Retires avec lui le 2026-07-19 : '@octaves.western' (bp3_indian porte les registres du
// moteur, dont le '00'), et '@tuning.sargam_22shruti' (lie a l'alphabet 'sargam' ET
// microtonal — il rendait une hauteur qui n'est pas celle du natif, en 12-TET).

// --- Sous-grammaire 1 @mode:random — structure ---

@mode:random
S -> Sri Ga Na Naa Da [weight:0]
S -> {sa4 _ _, - pitchbend(500) !(pitchcont, pitchrange: 500, pitchbend: 0)}
Sri -> {StartSlide StartPull sa3 _ Pull0 Slide0 _ Pull2 Slide5 _ Pull0 _ Pull2 _ Pull0 Slide5 _ Slide7 _ _ _ _ _ StopSlide StopPull}:2
Ga -> {LightGamaka pa3}:1
Na -> {sa4}:1
Naa -> {Spurita ni3}:1
Da -> {LightGamaka sa4}:1

-----

// --- Sous-grammaire 2 @mode:sub1 — structures intermédiaires ---

@mode:sub1
LightGamaka ?1 -> StartPull ?1 _ _ Pull0 _ Pull1 _ Pull0 _ _ _ Pull1 StopPull
Spurita ?1 -> StartSlide ?1 Slide1 _ _ _ _ _ _ _ Slide1 StopSlide

-----

// --- Sous-grammaire 3 @mode:sub1 — résolution en contrôles ---

@mode:sub1
Pull0 -> pitchbend(0)
Pull1 -> pitchbend(100)
Pull2 -> pitchbend(200)
Slide0 -> value(slide,0)
Slide1 -> value(slide,101)
Slide5 -> value(slide,501)
Slide7 -> value(slide,701)
StartSlide -> cont(slide) value(slide,0)
StopSlide -> fixed(slide)
StartPull -> pitchcont pitchrange(500) pitchbend(0)
StopPull -> pitchfixed
