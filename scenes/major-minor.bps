// major-minor.bps — Major vs Minor chords comparison
// Traduit de bp3-engine/library/examples/major-minor/grammar.gr

@core
@controls
@alphabet.western:midi
@mm:60
@striated

// --- Sous-grammaire 1 [mode:ord] ---

S -> Cmaj {C3,E3,G3,C4} [speed:2] scale(Cmin_minus,0) {C3,Eb3,G3,C4}[speed:2] Cmaj {C3,E3,G3,C4}[speed:2] - Cmaj {C3,E3,G3,C4}[speed:2] Cmin {C3,Eb3,G3,C4}[speed:2] Cmaj {C3,E3,G3,C4}[speed:2] [mode:ord]
S -> Seq1 - - Seq2
Seq1 -> {C3,E3,G3,C4} [speed:2] {C3,Eb3,G3,C4}[speed:2] {C3,E3,G3,C4}[speed:2] {C3,Eb3,G3,C4}[speed:2] {C3,E3,G3,C4}[speed:2]
Seq2 -> Cmaj {C3,E3,G3,C4} [speed:2] Cmin {C3,Eb3,G3,C4}[speed:2] Cmaj {C3,E3,G3,C4}[speed:2] Cmin {C3,Eb3,G3,C4}[speed:2] Cmaj {C3,E3,G3,C4}[speed:2]
Cmaj -> scale(Cmaj,0)
Cmin -> scale(Cmin,0)
