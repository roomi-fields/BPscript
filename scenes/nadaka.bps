// nadaka.bps — Improvisation in modern Carnatic style
// Traduit de bp3-engine/library/tabla/nadaka/grammar.gr
//
// Composed by Nadaka (nadaka@auroville.org.in) in July 1997.
// First attempt at Carnatic improvisation with octave variables.
// Notes in abbreviated Indian notation: S, R, G, M, P, N
// Octave variables Oc3/Oc4/Oc5 resolved in subgrammars 4-5.
//
// Bernard Bel added octave resolution rules (Oc1, Oc2...).
// This method is obsolete now that octave numbers are handled.

@core
@controls
@raga:midi

// ============================================================
// Sous-grammaire 1 — Structure [mode:ord]
// ============================================================

S -> scale(just_intonation,0) ins(1) Theme32 Theme32 Bridge32 Theme32 B32 Theme32 V16 V16 V16 V16 Theme32 V16 V16 V16 V16 Theme32 V16 V16 V16 V16 Theme32 V16 V16 V16 V16 Theme16 V16 Theme16 V16 Theme16 V16 Theme16 V16 Theme8 V8 Theme8 V8 Theme8 V8 Theme8 V8 Finale [weight:1] [mode:ord]
Finale -> Theme30 NiSaNiA95 NiSaNiB24 NiSaNiB24 NiSaNiC34 Morai49 Theme32 G _ _ _ _ _ _ _

-----

// ============================================================
// Sous-grammaire 2 — Variations [mode:random]
// ============================================================

V16 -> Oc4 G _ G G _ G R R G _ G G _ P G R [mode:random]
V16 -> Oc4 G R S Oc3 N P N Oc4 S R G P G R S Oc3 N Oc4 S R
V16 -> Oc4 G _ _ R S Oc3 N Oc4 S R G _ _ R S Oc3 N Oc4 S R
V16 -> Oc4 G _ _ P G R S R G _ _ P G R S R
V16 -> Oc4 G P N Oc5 S R G P G R S Oc4 N P G R S R

V8 -> Oc4 G _ G G _ P G R
V8 -> Oc4 G P G R S Oc3 N Oc4 S R
V8 -> Oc4 G _ _ R S Oc3 N Oc4 S R
V8 -> Oc4 G _ _ P G R S R
V8 -> Oc4 R S Oc4 N P G R S R

-----

// ============================================================
// Sous-grammaire 3 — Patterns fixes [mode:ord]
// ============================================================

NiSaNiA95 -> NiSaNiA18 P _ _ _ _ _ _ _ _ _ _ _ _ _ NiSaNiA18 G _ _ _ _ _ _ _ _ _ _ _ _ _ NiSaNiA18 R _ _ _ _ _ _ _ _ _ _ _ _ [mode:ord]
Morai49 -> Oc4 P Oc5 S S S Oc4 P G R S Oc3 N Oc4 S R S Oc3 N P G R S S S S R G P Oc4 S S S R G P N P S N _ P G R N P _ G R S P G _ R S R
NiSaNiA18 -> Oc4 N Oc5 S Oc4 N _ N N _ N N N N _ N N _ N N Oc5 S Oc4
NiSaNiB24 -> Oc4 P N Oc5 S Oc4 P _ _ _ _ _ P N Oc5 S Oc4 G _ _ _ _ _ P N Oc5 S Oc4 R _ _ _ _ _
NiSaNiC34 -> Oc4 P N Oc5 S Oc4 P P N Oc5 S Oc4 G P N Oc5 S Oc4 R Oc4 P N Oc5 S Oc4 P P N Oc5 S Oc4 G P N Oc5 S Oc4 R P N Oc5 S Oc4 P N Oc5 S Oc4 G N Oc5 S Oc4 R
Motto16 -> Oc4 G _ _ P N Oc5 S Oc4 N P N G _ P G R S Oc3 N

Theme32 -> Oc4 G _ _ P N Oc5 S Oc4 N P N G _ P G R S Oc3 N P N _ _ Oc4 R _ _ G _ _ _ _ _ 4
Theme30 -> Oc4 G _ _ P N Oc5 S Oc4 N P N G _ P G R S Oc3 N P N _ _ Oc4 R _ _ G _ _ _ _ _ 2
Theme16 -> Oc4 G _ _ P N Oc5 S Oc4 N P N G _ P G R S Oc3 N
Theme14 -> Oc4 G _ _ P N Oc5 S Oc4 N P N G _ P G R
Theme8 -> Oc4 N G _ P G R S Oc3 N

Bridge32 -> $Bridge6 &Bridge6
Bridge6 -> Oc4 G _ _ P _ _ N _ _ Oc5 R _ _ G _ S _

B32 -> Oc4 G _ P _ N _ Oc5 R _ G _ Oc4 G P N Oc5 R G S Oc4 G P N Oc5 R G S Oc4 G P N Oc5 R G S R G S R

-----

// ============================================================
// Sous-grammaire 4 — Résolution d'octaves [mode:ord]
// ============================================================

Oc3 S -> sa3 Oc3 [mode:ord]
Oc3 R -> re3 Oc3
Oc3 N -> ni3 Oc3
Oc3 P -> pa3 Oc3
Oc3 G -> ga3 Oc3
Oc3 _ -> _ Oc3

Oc4 S -> sa4 Oc4
Oc4 R -> re4 Oc4
Oc4 N -> ni4 Oc4
Oc4 P -> pa4 Oc4
Oc4 G -> ga4 Oc4
Oc4 _ -> _ Oc4

Oc5 S -> sa5 Oc5
Oc5 R -> re5 Oc5
Oc5 N -> ni5 Oc5
Oc5 P -> pa5 Oc5
Oc5 G -> ga5 Oc5
Oc5 _ -> _ Oc5

Oc3 Oc4 -> Oc4
Oc4 Oc5 -> Oc5
Oc3 Oc5 -> Oc5
Oc5 Oc4 -> Oc4
Oc4 Oc3 -> Oc3
Oc5 Oc3 -> Oc3

-----

// ============================================================
// Sous-grammaire 5 — Nettoyage [mode:ord]
// Efface les variables d'octave restantes
// ============================================================

Oc3 -> lambda [mode:ord]
Oc4 -> lambda
Oc5 -> lambda
