// --- Sous-grammaire 13 @mode:sub1 — Dancer instruments & rhythm ---

@mode:sub1
Smriti -> {3,Sm Sm Sm}
Olivier -> {5,Ol Ol Ol Ol Ol}
Vijayshree -> {2,Vi Vi}
Arindam -> {4,Ar Ar Ar Ar}
Somenath -> {6,So So So So So So}
Suresh -> {12,Su Su Su Su Su Su Su Su Su Su Su Su}

